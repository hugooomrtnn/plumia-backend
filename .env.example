# Copia este archivo a ".env" y rellena tus propios valores.
# El archivo .env NUNCA debe subirse a git (mira el .gitignore).

# Por defecto usa SQLite (un simple archivo, sin instalar nada más).
# Para usar Azure SQL Server más adelante:
#   DATABASE_URL=mssql+pyodbc://usuario:password@mvgmspain.database.windows.net/tu_bd?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=sqlite:///./plumia.db

# Cualquier cadena larga y aleatoria. Sirve para firmar los tokens de sesión.
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga

# Cuántos minutos dura la sesión antes de tener que volver a iniciar sesión.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Tu clave de la API de Anthropic. Consíguela en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# Límite de palabras por reescritura para el plan gratis.
FREE_WORD_LIMIT=2000
